# Copy this file to ".env" and fill in your secrets. The .env file is read by
# docker-compose and passed into the container as environment variables.
# Keep .env private -- never commit it.

TZ=Europe/London

# Bluesky (required for it to post)
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Mastodon (optional -- add when ready)
# MASTODON_API_BASE_URL=https://mastodon.social
# MASTODON_ACCESS_TOKEN=

# How often the container checks for a due slot (minutes)
INTERVAL_MINUTES=15
